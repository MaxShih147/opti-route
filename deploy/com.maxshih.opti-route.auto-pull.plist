  <key>StandardOutPath</key>
  <string>/Users/max_server/repo_claude/opti-route/logs/auto-pull.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/max_server/repo_claude/opti-route/logs/auto-pull.err.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/bin:/bin</string>
  </dict>
</dict>
</plist>
