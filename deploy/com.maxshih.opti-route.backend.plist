<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.maxshih.opti-route.backend</string>

  <key>WorkingDirectory</key>
  <string>/Users/max_server/repo_claude/opti-route</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/max_server/repo_claude/opti-route/.venv/bin/uvicorn</string>
    <string>backend.main:app</string>
    <string>--host</string>
    <string>127.0.0.1</string>
    <string>--port</string>
    <string>8765</string>
  </array>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ThrottleInterval</key>
  <integer>10</integer>

  <key>StandardOutPath</key>
  <string>/Users/max_server/repo_claude/opti-route/logs/backend.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/max_server/repo_claude/opti-route/logs/backend.err.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/Users/max_server/repo_claude/opti-route/.venv/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
    <key>PYTHONUNBUFFERED</key>
    <string>1</string>
  </dict>
</dict>
</plist>
